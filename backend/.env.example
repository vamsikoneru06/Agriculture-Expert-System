# ── Copy this file to .env and fill in your values ──
# For production (Railway/Render), set these as environment variables in the dashboard

# Flask
FLASK_ENV=production
SECRET_KEY=your-strong-secret-key-here

# MongoDB Atlas (required for cloud deployment)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=agriculture_expert_db

# JWT
JWT_SECRET_KEY=your-strong-jwt-secret-here
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24

# CORS — set this to your Vercel frontend URL (no trailing slash)
# Example: https://agriculture-expert-system.vercel.app
CORS_ORIGINS=https://your-app.vercel.app
